<?xml version="1.0"?>
<!--
  touch_tool_square_20x20.urdf
  TCP de palpação quadrado 20×20 mm para o Touch Pack (Gazebo Classic).

  Geometria da malha (STL, unidade original: mm):
    X: ±45 mm  (largura 90 mm — base de montagem)
    Y: ±45 mm  (profundidade 90 mm)
    Z: -6.5 mm … +108 mm  (comprimento total ≈ 114.5 mm)

  Cadeia de links:
    Link6 → lower_coupling_link (acoplador ⌀80×15 mm) → force_sensor_link (célula 60 mm)
          → upper_coupling_link (acoplador ⌀80×15 mm) → touch_tool_link → tcp_link

  Convenção de frames:
    • lower_coupling_link / origem: coincide com o flange do robô (Link6).
      Disco ⌀80×15 mm, slot 52×13 mm encaixa a base da célula de carga.
    • force_sensor_link / origem: topo do acoplador inferior (+15 mm de Link6).
      Célula de carga 50.8×60×12.7 mm, mesh centralizado em X/Y por offset visual.
    • upper_coupling_link / origem: topo da célula em pé (+15+60=75 mm de Link6).
      Mesmo disco do inferior; slot encaixa o topo da célula.
    • touch_tool_link / origem: topo do acoplador superior (+75+15=90 mm de Link6).
      O fundo do STL (Z = -6.5 mm no espaço da malha) é alinhado com +0.0065 m.
    • tcp_link: face de contato quadrada 20×20 mm (ponta do probe),
      situado em 0.007+0.052+0.015+0.1145 = 0.1885 m acima do flange (Link6).
      A célula entra 8 mm dentro de cada acoplador (slot 52×13 mm passante).

  Uso standalone (Gazebo):
    Altere o parent do joint "touch_tool_attach" de "Link6" para "world",
    remova o joint "world_to_base" abaixo e spawn via spawn_entity.py.

  Integração no launch (típico):
    Injete o conteúdo entre <robot>…</robot> no URDF combinado do CR10,
    após a definição de Link6, e remova o bloco <robot name="standalone"> deste
    arquivo (use apenas o corpo interno como fragmento xacro/snippet).
-->
<robot name="touch_tool_tcp">

  <!-- ══════════════════════════════════════════════════════════════════
       ROOT (modo standalone): liga a ferramenta ao world para teste.
       Na integração com o CR10 este bloco é substituído por Link6
       como parent direto do joint "touch_tool_attach".
  ══════════════════════════════════════════════════════════════════ -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="Link6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Placeholder Link6 (robô real — substituído pelo CR10 na integração). -->
  <link name="Link6">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-9" ixy="0.0" ixz="0.0"
               iyy="1e-9" iyz="0.0" izz="1e-9"/>
    </inertial>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       ACOPLADOR INFERIOR (entre Link6 e célula de carga)
       Disco ⌀80×15 mm em alumínio; slot 52×13 mm encaixa na base da célula.
       Mesh: X[−40..40] Y[−40..40] Z[0..15] mm — já centrado em X/Y.
  ══════════════════════════════════════════════════════════════════ -->
  <link name="lower_coupling_link">
    <inertial>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <mass value="0.200"/>
      <!-- disco Al: Ixx=Iyy=(1/12)m(3R²+H²)=8.4e-5; Izz=(1/2)mR²=1.6e-4 -->
      <inertia ixx="8.4e-5" ixy="0.0" ixz="0.0"
               iyy="8.4e-5" iyz="0.0"
               izz="1.6e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/Acoplador_CelulaDeCarga_Uniaxial.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="coupling_gray">
        <color rgba="0.35 0.35 0.40 1.0"/>
      </material>
    </visual>
    <collision name="col_lower_coupling">
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.015"/>
      </geometry>
    </collision>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       CÉLULA DE CARGA (entre acoplador inferior e acoplador superior)
       STL original: X[0..50.8] Y[0..60] Z[0..12.7] mm — unidade mm.
       Offset visual −25.4 mm em X e −30 mm em Y para centralizar o mesh
       no eixo Z do flange. Colisão: caixa 50.8×60×12.7 mm.
  ══════════════════════════════════════════════════════════════════ -->
  <link name="force_sensor_link">
    <inertial>
      <!-- em pé: 50.8×12.7×60 mm, CoM no centro geométrico -->
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <mass value="0.150"/>
      <inertia ixx="4.70e-5" ixy="0.0" ixz="0.0"
               iyy="7.73e-5" iyz="0.0"
               izz="3.43e-5"/>
    </inertial>
    <!-- Rx(+90°): mesh-Y(60mm) → +Z do robô (célula em pé) -->
    <visual>
      <origin xyz="-0.0254 0.00635 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/Celula De Carga.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver">
        <color rgba="0.80 0.80 0.85 1.0"/>
      </material>
    </visual>
    <collision name="col_sensor">
      <origin xyz="0 0 0.030" rpy="0 0 0"/>
      <geometry>
        <box size="0.0508 0.0127 0.060"/>
      </geometry>
    </collision>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       ACOPLADOR SUPERIOR (entre célula de carga e touch_tool)
       Mesma geometria do inferior; encaixa no topo da célula de carga.
  ══════════════════════════════════════════════════════════════════ -->
  <link name="upper_coupling_link">
    <inertial>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <mass value="0.200"/>
      <inertia ixx="8.4e-5" ixy="0.0" ixz="0.0"
               iyy="8.4e-5" iyz="0.0"
               izz="1.6e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/Acoplador_CelulaDeCarga_Uniaxial.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="coupling_gray">
        <color rgba="0.35 0.35 0.40 1.0"/>
      </material>
    </visual>
    <collision name="col_upper_coupling">
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.015"/>
      </geometry>
    </collision>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════
       CORPO PRINCIPAL DO TCP
  ══════════════════════════════════════════════════════════════════ -->
  <link name="touch_tool_link">

    <!--
      Inércia estimada: alumínio 6061, ≈ 150 g, corpo aproximado como
      caixa uniforme 90×90×114.5 mm:
        Ixx = Iyy = (1/12)·m·(w² + h²) = (1/12)·0.15·(0.009+0.0131) ≈ 2.65e-4 kg·m²
        Izz        = (1/12)·m·(w² + w²) = (1/12)·0.15·0.0162         ≈ 2.03e-4 kg·m²
      CoM no centro geométrico: Z_cm ≈ (6.5 + 114.5/2) mm = 63.75 mm → 0.064 m
    -->
    <inertial>
      <origin xyz="0 0 0.064" rpy="0 0 0"/>
      <mass value="0.150"/>
      <inertia ixx="2.65e-4" ixy="0.0" ixz="0.0"
               iyy="2.65e-4" iyz="0.0"
               izz="2.03e-4"/>
    </inertial>

    <!-- Visual: malha STL (mm → m via scale). Offset +0.0065 m em Z para
         alinhar o fundo do STL (Z_mesh = -6.5 mm) com a origem do link. -->
    <visual>
      <origin xyz="0 0 0.0065" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://touch_pack/meshes/touch_tool_square_20x20.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_red">
        <color rgba="1.0 0.50 0.50 1.0"/>
      </material>
    </visual>

    <!--
      Colisão simplificada (duas caixas) — mais estável no ODE do Gazebo
      do que a malha completa com 14 822 triângulos.

      col_body  → corpo/base de montagem: cobre Z = 0 … 0.094 m
                  (90×90 mm de largura, acompanha a seção principal).
      col_tip   → haste + face 20×20 mm: cobre Z ≈ 0.087 … 0.125 m
                  (25×25 mm com 1 mm de margem lateral).
    -->
    <collision name="col_body">
      <origin xyz="0 0 0.047" rpy="0 0 0"/>
      <geometry>
        <box size="0.090 0.090 0.094"/>
      </geometry>
    </collision>

    <collision name="col_tip">
      <origin xyz="0 0 0.106" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.038"/>
      </geometry>
    </collision>

  </link>

  <!-- Frame tcp_link na face de contato (ponta do probe 20×20 mm). -->
  <link name="tcp_link"/>

  <!-- ══════════════════════════════════════════════════════════════════
       JUNTAS
       Célula entra 8 mm dentro de cada acoplador (slot passante 52×13 mm);
       7 mm de anel do acoplador fica visível em cada extremidade da célula.

       Cadeia e offsets (medidos a partir de Link6):
         lower_coupling  0 mm       (flange)
         force_sensor    +7 mm      (célula entra 8 mm no acoplador inferior)
         upper_coupling  +59 mm     (célula entra 8 mm no acoplador superior)
         touch_tool      +74 mm
         tcp_link        +188.5 mm
  ══════════════════════════════════════════════════════════════════ -->
  <!-- Acoplador inferior no flange. -->
  <joint name="lower_coupling_attach" type="fixed">
    <parent link="Link6"/>
    <child link="lower_coupling_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Célula inicia 7 mm acima do flange — entra 8 mm no acoplador inferior. -->
  <joint name="force_sensor_attach" type="fixed">
    <parent link="lower_coupling_link"/>
    <child link="force_sensor_link"/>
    <origin xyz="0 0 0.007" rpy="0 0 0"/>
  </joint>

  <!-- Acoplador superior começa 8 mm antes do topo da célula (+52 mm). -->
  <joint name="upper_coupling_attach" type="fixed">
    <parent link="force_sensor_link"/>
    <child link="upper_coupling_link"/>
    <origin xyz="0 0 0.052" rpy="0 0 0"/>
  </joint>

  <!-- Touch tool sobre o acoplador superior (+15 mm). -->
  <joint name="touch_tool_attach" type="fixed">
    <parent link="upper_coupling_link"/>
    <child link="touch_tool_link"/>
    <origin xyz="0 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- tcp_link na ponta: 6.5 mm (offset base) + 108 mm (tip) = 114.5 mm. -->
  <joint name="tcp_alias_joint" type="fixed">
    <parent link="touch_tool_link"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 0.1145" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════
       PROPRIEDADES GAZEBO
  ══════════════════════════════════════════════════════════════════ -->
  <gazebo reference="touch_tool_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.60</mu1>
    <mu2>0.60</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
  </gazebo>

  <gazebo reference="Link6">
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="force_sensor_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.40</mu1>
    <mu2>0.40</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
  </gazebo>

  <gazebo reference="lower_coupling_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.40</mu1>
    <mu2>0.40</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
  </gazebo>

  <gazebo reference="upper_coupling_link">
    <self_collide>false</self_collide>
    <gravity>true</gravity>
    <mu1>0.40</mu1>
    <mu2>0.40</mu2>
    <kp>1.0e5</kp>
    <kd>100.0</kd>
    <maxContacts>4</maxContacts>
    <minDepth>0.0002</minDepth>
    <maxVel>0.05</maxVel>
  </gazebo>

</robot>
